# ConnectWise Manage MCP Server - Environment Variables
# Copy this to .env and fill in your values

# CWM instance hostname (no https://, no trailing slash)
CWM_SITE=your-cwm-instance.example.com

# Your CWM company ID (the login company, not a numeric ID)
CWM_COMPANY_ID=YourCompanyId

# API member public key (from System > Members > API Keys)
CWM_PUBLIC_KEY=your_public_key_here

# API member private key
CWM_PRIVATE_KEY=your_private_key_here

# Registered developer client ID (GUID from developer.connectwise.com)
CWM_CLIENT_ID=your-client-id-guid-here

# Optional: enable raw escape-hatch tools (off by default)
CWM_ENABLE_RAW_TOOLS=false

# Optional: max pages for paginateAll (default 20)
CWM_MAX_PAGES=20

# Optional: log level (default info)
LOG_LEVEL=info
